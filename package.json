{
  "name": "collection-of-beauty",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "dev": "docker-compose up --build",
    "dev:local": "npm run build:data && next dev",
    "dev:down": "docker-compose down",
    "dev:logs": "docker-compose logs -f",
    "build": "npm run build:data && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "email:dev": "email dev --dir ./emails --port 3001",
    "scrape:fetch": "node scripts/fetch-wikimedia-metadata.mjs",
    "scrape:resolve": "node scripts/resolve-unresolved.mjs",
    "scrape:classify": "node scripts/classify-unresolved.mjs",
    "download:birds": "bash scripts/download-birds-of-america.sh",
    "download:kunstformen": "bash scripts/download-kunstformen.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "form-data": "^4.0.5",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "mailgun.js": "^13.0.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.10",
    "react-email": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
