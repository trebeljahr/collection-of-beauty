{
  "name": "collection-of-beauty",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "assets:serve": "node scripts/serve-assets.mjs",
    "assets:docker:up": "docker-compose up -d assets",
    "assets:docker:down": "docker-compose down",
    "assets:docker:logs": "docker-compose logs -f assets",
    "dev": "node scripts/dev.mjs",
    "build": "npm run build:data && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "email:dev": "email dev --dir ./emails --port 3001",
    "scrape:fetch": "node scripts/fetch-wikimedia-metadata.mjs",
    "scrape:resolve": "node scripts/resolve-unresolved.mjs",
    "scrape:classify": "node scripts/classify-unresolved.mjs",
    "download:birds": "bash scripts/download-birds-of-america.sh",
    "download:kunstformen": "bash scripts/download-kunstformen.sh",
    "shrink": "node scripts/shrink-sources.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@three.ez/instanced-mesh": "^0.3.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "form-data": "^4.0.5",
    "fuse.js": "^7.3.0",
    "image-size": "^2.0.2",
    "lucide-react": "^1.8.0",
    "mailgun.js": "^13.0.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-photo-album": "^3.6.0",
    "seedrandom": "^3.0.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.184.0",
    "postcss": "^8.5.10",
    "react-email": "^6.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
