.git
.gitignore
.gitattributes
.claude

# Env & secrets
.env
.env.*
!.env.example

# Editor / OS cruft
.vscode
.idea
.DS_Store

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Docker itself
Dockerfile*
docker-compose*.yml
.dockerignore
