# Copy to .env.local and adjust for your setup.

# Base URL the browser uses to fetch artwork images. Defaults (in code) to the
# local shared MinIO bucket when unset — override to point at R2, a public
# CDN, or a different port.
NEXT_PUBLIC_ASSETS_BASE_URL=http://localhost:9000/collection-of-beauty

# The upload script talks to the same MinIO via docker exec. Override if your
# shared container has a different name or credentials.
# MINIO_CONTAINER=great-gates-minio-1
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# MINIO_BUCKET=collection-of-beauty
