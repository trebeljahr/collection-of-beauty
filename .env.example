# Copy to .env.local and adjust for your setup.

# Base URL the browser uses to fetch artwork variants (pre-built AVIF/WebP
# files + originals). Defaults (in code) to the rclone HTTP server run by
# docker-compose on :9100. Override to point at R2, a public CDN, or any
# other HTTP file host.
NEXT_PUBLIC_ASSETS_BASE_URL=http://localhost:9100

# Canonical site URL (used for artwork links in the email). In Vercel prod,
# VERCEL_PROJECT_PRODUCTION_URL is used as a fallback if this is unset.
# NEXT_PUBLIC_SITE_URL=https://collection-of-beauty.example.com

# ─────────────────────────────────────────────────────────────────────────────
# Weekly newsletter (Mailgun + Cloudflare R2 state file)
# ─────────────────────────────────────────────────────────────────────────────

# Vercel Cron authorization. Vercel sends `Authorization: Bearer $CRON_SECRET`
# to /api/newsletter/send. Generate with: openssl rand -hex 32
# CRON_SECRET=

# Mailgun — the weekly digest sends to a Mailgun mailing list address, which
# Mailgun fans out to subscribers. Create a list in the Mailgun dashboard
# under "Sending → Mailing Lists", then point MAILGUN_LIST at its address.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_FROM="Collection of Beauty <digest@mg.example.com>"
# MAILGUN_LIST=weekly@mg.example.com
# For EU accounts, uncomment:
# MAILGUN_API_URL=https://api.eu.mailgun.net

# Cloudflare R2 credentials — used for both the newsletter state file
# (private) and the public assets bucket. Same R2 account, separate
# buckets keeps blast radius small if the public-read token leaks.
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Newsletter state — a small JSON file tracking which artworks have been
# sent. NOT publicly readable.
# R2_STATE_BUCKET=collection-of-beauty-state
# R2_STATE_KEY=newsletter-state.json

# Pre-built variant assets (AVIF/WebP) for the production site. Public-read,
# served directly to browsers. Sync with `pnpm assets:sync` after every
# `pnpm shrink`. Set NEXT_PUBLIC_ASSETS_BASE_URL above to this bucket's
# public URL (R2 dev URL or a custom domain) for prod builds.
# R2_ASSETS_BUCKET=collection-of-beauty-assets
