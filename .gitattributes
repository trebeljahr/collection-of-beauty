*.jpg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text

# Poly Haven PBR textures are small (≤2 MB each, ~18 MB total) and
# CC0, so we ship them as regular Git blobs rather than LFS objects.
# Without this exception they get LFS-cleaned on commit and the local
# clone gets 131-byte pointer files at checkout (the repo configures
# `smudge --skip`), which the dev server happily serves with
# Content-Type: image/jpeg — three.js then can't decode them and the
# 3D gallery falls back to mirror-finish floors reflecting the env map.
public/textures/**/*.jpg !filter !diff !merge -text
